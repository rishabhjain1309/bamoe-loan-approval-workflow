<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:tns="http://www.jbpm.org/bpmn2/bpmn-extensions"
             targetNamespace="http://www.rebit.com/bamoe"
             id="Definitions_LoanApproval">

  <itemDefinition id="__dT_Long"    structureRef="java.lang.Long"/>
  <itemDefinition id="__dT_String"  structureRef="java.lang.String"/>
  <itemDefinition id="__dT_Boolean" structureRef="java.lang.Boolean"/>

  <process id="LoanApprovalProcess"
           name="Loan Approval Process"
           isExecutable="true"
           processType="Public">

    <property id="applicationId"   name="applicationId"   itemSubjectRef="__dT_Long"/>
    <property id="makerAssignee"   name="makerAssignee"   itemSubjectRef="__dT_String"/>
    <property id="checkerAssignee" name="checkerAssignee" itemSubjectRef="__dT_String"/>
    <property id="makerDecision"   name="makerDecision"   itemSubjectRef="__dT_String"/>
    <property id="checkerDecision" name="checkerDecision" itemSubjectRef="__dT_String"/>
    <property id="comments"        name="comments"        itemSubjectRef="__dT_String"/>
    <property id="approved"        name="approved"        itemSubjectRef="__dT_Boolean"/>

    <startEvent id="Start" name="Application Submitted">
      <outgoing>flow_start_to_join</outgoing>
    </startEvent>

    <exclusiveGateway id="JoinToMaker" name="Route to Maker" gatewayDirection="Converging">
      <incoming>flow_start_to_join</incoming>
      <incoming>flow_sendback_to_join</incoming>
      <incoming>flow_edit_to_join</incoming>
      <outgoing>flow_join_to_maker</outgoing>
    </exclusiveGateway>

    <userTask id="MakerReview" name="Maker Review">
      <documentation>Maker reviews the application: Approve, Reject, or Request Edit</documentation>
      <incoming>flow_join_to_maker</incoming>
      <outgoing>flow_maker_to_gateway</outgoing>
      <potentialOwner>
        <resourceAssignmentExpression>
          <formalExpression>${makerAssignee}</formalExpression>
        </resourceAssignmentExpression>
      </potentialOwner>
      <ioSpecification>
        <dataInput id="di_makerDecision" name="makerDecision"/>
        <dataInput id="di_comments_m"    name="comments"/>
        <dataOutput id="do_makerDecision" name="makerDecision"/>
        <dataOutput id="do_comments_m"    name="comments"/>
        <inputSet>
          <dataInputRefs>di_makerDecision</dataInputRefs>
          <dataInputRefs>di_comments_m</dataInputRefs>
        </inputSet>
        <outputSet>
          <dataOutputRefs>do_makerDecision</dataOutputRefs>
          <dataOutputRefs>do_comments_m</dataOutputRefs>
        </outputSet>
      </ioSpecification>
      <dataInputAssociation>
        <sourceRef>makerDecision</sourceRef>
        <targetRef>di_makerDecision</targetRef>
      </dataInputAssociation>
      <dataInputAssociation>
        <sourceRef>comments</sourceRef>
        <targetRef>di_comments_m</targetRef>
      </dataInputAssociation>
      <dataOutputAssociation>
        <sourceRef>do_makerDecision</sourceRef>
        <targetRef>makerDecision</targetRef>
      </dataOutputAssociation>
      <dataOutputAssociation>
        <sourceRef>do_comments_m</sourceRef>
        <targetRef>comments</targetRef>
      </dataOutputAssociation>
    </userTask>

    <exclusiveGateway id="MakerGateway" name="Maker Decision" gatewayDirection="Diverging">
      <incoming>flow_maker_to_gateway</incoming>
      <outgoing>flow_maker_approve</outgoing>
      <outgoing>flow_maker_reject</outgoing>
      <outgoing>flow_maker_edit</outgoing>
    </exclusiveGateway>

    <scriptTask id="NotifyEdit" name="Notify Edit Requested" scriptFormat="http://www.java.com/java">
      <incoming>flow_maker_edit</incoming>
      <outgoing>flow_edit_to_join</outgoing>
      <script>System.out.println("Edit requested for application: " + applicationId);</script>
    </scriptTask>

    <userTask id="CheckerReview" name="Checker Review">
      <documentation>Checker performs final review: Approve, Reject, or Send Back to Maker</documentation>
      <incoming>flow_maker_approve</incoming>
      <outgoing>flow_checker_to_gateway</outgoing>
      <potentialOwner>
        <resourceAssignmentExpression>
          <formalExpression>${checkerAssignee}</formalExpression>
        </resourceAssignmentExpression>
      </potentialOwner>
      <ioSpecification>
        <dataInput id="di_checkerDecision" name="checkerDecision"/>
        <dataInput id="di_comments_c"      name="comments"/>
        <dataOutput id="do_checkerDecision" name="checkerDecision"/>
        <dataOutput id="do_comments_c"      name="comments"/>
        <inputSet>
          <dataInputRefs>di_checkerDecision</dataInputRefs>
          <dataInputRefs>di_comments_c</dataInputRefs>
        </inputSet>
        <outputSet>
          <dataOutputRefs>do_checkerDecision</dataOutputRefs>
          <dataOutputRefs>do_comments_c</dataOutputRefs>
        </outputSet>
      </ioSpecification>
      <dataInputAssociation>
        <sourceRef>checkerDecision</sourceRef>
        <targetRef>di_checkerDecision</targetRef>
      </dataInputAssociation>
      <dataInputAssociation>
        <sourceRef>comments</sourceRef>
        <targetRef>di_comments_c</targetRef>
      </dataInputAssociation>
      <dataOutputAssociation>
        <sourceRef>do_checkerDecision</sourceRef>
        <targetRef>checkerDecision</targetRef>
      </dataOutputAssociation>
      <dataOutputAssociation>
        <sourceRef>do_comments_c</sourceRef>
        <targetRef>comments</targetRef>
      </dataOutputAssociation>
    </userTask>

    <exclusiveGateway id="CheckerGateway" name="Checker Decision" gatewayDirection="Diverging">
      <incoming>flow_checker_to_gateway</incoming>
      <outgoing>flow_checker_approve</outgoing>
      <outgoing>flow_checker_reject</outgoing>
      <outgoing>flow_sendback_to_join</outgoing>
    </exclusiveGateway>

    <endEvent id="EndApproved" name="Approved">
      <incoming>flow_checker_approve</incoming>
    </endEvent>

    <endEvent id="EndRejectedMaker" name="Rejected by Maker">
      <incoming>flow_maker_reject</incoming>
    </endEvent>

    <endEvent id="EndRejectedChecker" name="Rejected by Checker">
      <incoming>flow_checker_reject</incoming>
    </endEvent>

    <sequenceFlow id="flow_start_to_join"      sourceRef="Start"          targetRef="JoinToMaker"/>
    <sequenceFlow id="flow_join_to_maker"      sourceRef="JoinToMaker"    targetRef="MakerReview"/>
    <sequenceFlow id="flow_maker_to_gateway"   sourceRef="MakerReview"    targetRef="MakerGateway"/>

    <sequenceFlow id="flow_maker_approve" name="Approve" sourceRef="MakerGateway" targetRef="CheckerReview">
      <conditionExpression xsi:type="tFormalExpression" language="http://www.java.com/java"><![CDATA[return makerDecision != null && makerDecision.equals("APPROVE");]]></conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_maker_reject" name="Reject" sourceRef="MakerGateway" targetRef="EndRejectedMaker">
      <conditionExpression xsi:type="tFormalExpression" language="http://www.java.com/java"><![CDATA[return makerDecision != null && makerDecision.equals("REJECT");]]></conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_maker_edit" name="Request Edit" sourceRef="MakerGateway" targetRef="NotifyEdit">
      <conditionExpression xsi:type="tFormalExpression" language="http://www.java.com/java"><![CDATA[return makerDecision != null && makerDecision.equals("REQUEST_EDIT");]]></conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow_edit_to_join"       sourceRef="NotifyEdit"     targetRef="JoinToMaker"/>
    <sequenceFlow id="flow_checker_to_gateway" sourceRef="CheckerReview"  targetRef="CheckerGateway"/>

    <sequenceFlow id="flow_checker_approve" name="Approve" sourceRef="CheckerGateway" targetRef="EndApproved">
      <conditionExpression xsi:type="tFormalExpression" language="http://www.java.com/java"><![CDATA[return checkerDecision != null && checkerDecision.equals("APPROVE");]]></conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_checker_reject" name="Reject" sourceRef="CheckerGateway" targetRef="EndRejectedChecker">
      <conditionExpression xsi:type="tFormalExpression" language="http://www.java.com/java"><![CDATA[return checkerDecision != null && checkerDecision.equals("REJECT");]]></conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_sendback_to_join" name="Send Back" sourceRef="CheckerGateway" targetRef="JoinToMaker">
      <conditionExpression xsi:type="tFormalExpression" language="http://www.java.com/java"><![CDATA[return checkerDecision != null && checkerDecision.equals("SEND_BACK");]]></conditionExpression>
    </sequenceFlow>

  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="LoanApprovalProcess">

      <bpmndi:BPMNShape id="shape_Start" bpmnElement="Start">
        <dc:Bounds x="60" y="232" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="36" y="275" width="84" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_JoinToMaker" bpmnElement="JoinToMaker" isMarkerVisible="true">
        <dc:Bounds x="155" y="225" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="138" y="282" width="84" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_MakerReview" bpmnElement="MakerReview">
        <dc:Bounds x="270" y="210" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_MakerGateway" bpmnElement="MakerGateway" isMarkerVisible="true">
        <dc:Bounds x="455" y="225" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="437" y="282" width="86" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_NotifyEdit" bpmnElement="NotifyEdit">
        <dc:Bounds x="430" y="370" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_CheckerReview" bpmnElement="CheckerReview">
        <dc:Bounds x="620" y="210" width="120" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_CheckerGateway" bpmnElement="CheckerGateway" isMarkerVisible="true">
        <dc:Bounds x="805" y="225" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="783" y="282" width="94" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_EndApproved" bpmnElement="EndApproved">
        <dc:Bounds x="952" y="232" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="936" y="275" width="68" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_EndRejectedMaker" bpmnElement="EndRejectedMaker">
        <dc:Bounds x="455" y="102" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="428" y="72" width="90" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_EndRejectedChecker" bpmnElement="EndRejectedChecker">
        <dc:Bounds x="805" y="102" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="774" y="72" width="98" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="edge_start_join" bpmnElement="flow_start_to_join">
        <di:waypoint x="96"  y="250"/><di:waypoint x="155" y="250"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_join_maker" bpmnElement="flow_join_to_maker">
        <di:waypoint x="205" y="250"/><di:waypoint x="270" y="250"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_maker_gw" bpmnElement="flow_maker_to_gateway">
        <di:waypoint x="390" y="250"/><di:waypoint x="455" y="250"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_maker_approve" bpmnElement="flow_maker_approve">
        <di:waypoint x="505" y="250"/><di:waypoint x="620" y="250"/>
        <bpmndi:BPMNLabel><dc:Bounds x="539" y="230" width="44" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_maker_reject" bpmnElement="flow_maker_reject">
        <di:waypoint x="480" y="225"/><di:waypoint x="480" y="138"/>
        <bpmndi:BPMNLabel><dc:Bounds x="488" y="170" width="34" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_maker_edit" bpmnElement="flow_maker_edit">
        <di:waypoint x="480" y="275"/><di:waypoint x="480" y="370"/>
        <bpmndi:BPMNLabel><dc:Bounds x="488" y="310" width="60" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_edit_join" bpmnElement="flow_edit_to_join">
        <di:waypoint x="430" y="410"/><di:waypoint x="180" y="410"/><di:waypoint x="180" y="275"/>
        <bpmndi:BPMNLabel><dc:Bounds x="268" y="392" width="74" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_checker_gw" bpmnElement="flow_checker_to_gateway">
        <di:waypoint x="740" y="250"/><di:waypoint x="805" y="250"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_checker_approve" bpmnElement="flow_checker_approve">
        <di:waypoint x="855" y="250"/><di:waypoint x="952" y="250"/>
        <bpmndi:BPMNLabel><dc:Bounds x="882" y="230" width="44" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_checker_reject" bpmnElement="flow_checker_reject">
        <di:waypoint x="830" y="225"/><di:waypoint x="830" y="138"/>
        <bpmndi:BPMNLabel><dc:Bounds x="838" y="170" width="34" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_sendback_join" bpmnElement="flow_sendback_to_join">
        <di:waypoint x="830" y="275"/><di:waypoint x="830" y="490"/>
        <di:waypoint x="180" y="490"/><di:waypoint x="180" y="275"/>
        <bpmndi:BPMNLabel><dc:Bounds x="482" y="472" width="56" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>